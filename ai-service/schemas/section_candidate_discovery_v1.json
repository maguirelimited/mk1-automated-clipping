{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "section_candidate_discovery_v1"
    },
    "section_id": {
      "minLength": 1,
      "type": "string"
    },
    "usable": {
      "type": "boolean"
    },
    "confidence": {
      "maximum": 1,
      "minimum": 0,
      "type": "number"
    },
    "reason": {
      "type": "string"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "candidates": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "candidate_local_id": {
            "minLength": 1,
            "type": "string"
          },
          "source_section_id": {
            "minLength": 1,
            "type": "string"
          },
          "start_sec": {
            "type": "number"
          },
          "end_sec": {
            "type": "number"
          },
          "duration_sec": {
            "type": "number"
          },
          "hook_text": {
            "minLength": 1,
            "type": "string"
          },
          "core_idea_summary": {
            "minLength": 1,
            "type": "string"
          },
          "why_candidate_has_potential": {
            "minLength": 1,
            "type": "string"
          },
          "archetype": {
            "enum": [
              "valuable_insight",
              "funny_moment",
              "controversial_opinion",
              "story",
              "explanation",
              "emotional_moment",
              "surprising_fact",
              "tactical_advice",
              "business_lesson",
              "strong_quote",
              "other"
            ],
            "type": "string"
          },
          "scores": {
            "additionalProperties": false,
            "properties": {
              "hook_strength": {
                "maximum": 10,
                "minimum": 0,
                "type": "integer"
              },
              "standalone_context": {
                "maximum": 10,
                "minimum": 0,
                "type": "integer"
              },
              "insight_value": {
                "maximum": 10,
                "minimum": 0,
                "type": "integer"
              },
              "retention_potential": {
                "maximum": 10,
                "minimum": 0,
                "type": "integer"
              },
              "natural_ending": {
                "maximum": 10,
                "minimum": 0,
                "type": "integer"
              },
              "overall_potential": {
                "maximum": 10,
                "minimum": 0,
                "type": "integer"
              }
            },
            "required": [
              "hook_strength",
              "standalone_context",
              "insight_value",
              "retention_potential",
              "natural_ending",
              "overall_potential"
            ],
            "type": "object"
          },
          "confidence": {
            "maximum": 1,
            "minimum": 0,
            "type": "number"
          },
          "warnings": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "candidate_local_id",
          "start_sec",
          "end_sec",
          "duration_sec",
          "hook_text",
          "core_idea_summary",
          "why_candidate_has_potential",
          "archetype",
          "scores",
          "confidence",
          "warnings"
        ],
        "type": "object"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "section_id",
    "usable",
    "confidence",
    "reason",
    "warnings",
    "candidates"
  ],
  "type": "object"
}
