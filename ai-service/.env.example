# ai-service (local LLM) dev defaults. Copy to ai-service/.env and edit locally.
# Only consumed in DEV; PROD reads /etc/mk04/prod/env and the run scripts.

# Bind address for the Flask service.
AI_SERVICE_HOST=127.0.0.1
AI_SERVICE_PORT=5075
AI_SERVICE_DEBUG=0

# Model backend. Defaults target a local Ollama instance.
# These can also be set from the Ops UI (Settings -> Local AI & clip selection),
# which writes controls.json. ai-service resolves each value as:
#   Ops UI saved value -> this env var -> built-in default.
AI_PROVIDER=ollama
AI_MODEL=qwen2.5:14b-instruct
AI_BASE_URL=http://localhost:11434
AI_TIMEOUT_SECONDS=120
AI_TEMPERATURE=0.2
AI_TOP_P=0.9
AI_MAX_TOKENS=1200

# How long Ollama keeps the model resident in VRAM after a call. "5m" matches
# Ollama's default and means the 14B model is evicted after the idle window, so
# the GPU is freed for the next WhisperX transcription instead of being pinned
# forever. Use "0" to unload immediately after each call; avoid "-1" (pins the
# model in VRAM forever) on a single shared GPU.
AI_KEEP_ALIVE=5m

# Ollama startup helper (deploy/scripts/run-ollama.sh). When true, a missing
# model is pulled automatically on startup (can be a large download). Default
# false: the UI/logs tell you to run 'ollama pull <model>' instead.
OLLAMA_AUTO_PULL_MODEL=false
