# mk0.4 source-input service environment
# Copy to .env (or source from your process manager) for deployment.
# Values below are examples/placeholders. Replace /opt/mk04/VAmk0.4 with the
# real absolute Linux path to this repo checkout.

INPUT_SERVICE_HOST=127.0.0.1
INPUT_SERVICE_PORT=5060
INPUT_SERVICE_DEBUG=0
INPUT_SERVICE_LOG_LEVEL=INFO

# Optional. If set, /run-funnel, /funnels, and /doctor require this header:
# X-Input-Service-Secret: <value>
INPUT_SERVICE_SECRET=

# Strongly recommended for Linux/process-manager deployments: absolute root for
# config/ and data/ paths. Keep data/ on durable storage if duplicate tracking
# and downloaded input state must survive restarts.
INPUT_SERVICE_ROOT=/opt/mk04/VAmk0.4/source-input/input_service

# Optional: parent directory of ``video-automation`` (folder that contains ``video-automation/config/``).
# Use if the input service cannot find ``video-automation`` by walking up from INPUT_SERVICE_ROOT.
# VIDEO_AUTOMATION_PROJECT_ROOT=

# Optional explicit clipping input directory (must match ``paths.input_folder`` in pipeline_config.json).
# Default: <parent>/video-automation/input
# Use a real absolute Linux path if video automation input lives on mounted storage.
VIDEO_AUTOMATION_INPUT_DIR=

# Video-automation HTTP API (auto-enqueue clipping after input_ready). Default: http://127.0.0.1:5050
# VIDEO_AUTOMATION_BASE_URL=http://127.0.0.1:5050
# VIDEO_AUTOMATION_HOST=127.0.0.1
# VIDEO_AUTOMATION_PORT=5050
# Set to 0 to disable automatic POST /jobs (n8n trigger-only without clipping handoff).
CLIPPING_AUTO_ENQUEUE=1

# yt-dlp auth for YouTube bot / sign-in challenges. For autonomous mk1
# operation on a headless server, Netscape cookies.txt is the reliable path.
# Export from a browser extension ("Get cookies.txt LOCALLY") and place the
# file on durable storage so refreshes survive restarts. Re-export when
# YouTube rotates the session (~weekly to monthly).
YT_DLP_COOKIES_PATH=/var/lib/mk04/cookies/youtube.cookies.txt
# Alternative: browser keyring on a desktop host. Not recommended for servers.
# YT_DLP_COOKIES_FROM_BROWSER=chrome

# Optional JavaScript runtime for YouTube n-challenge solving.
# Equivalent to: yt-dlp --js-runtimes deno
# YT_DLP_JS_RUNTIME=deno
# Optional explicit Deno binary path:
# YT_DLP_DENO_PATH=/path/to/deno
