# mk0.4 source-input service environment
# Copy to .env (or source from your process manager) for deployment.

INPUT_SERVICE_HOST=127.0.0.1
INPUT_SERVICE_PORT=5060
INPUT_SERVICE_DEBUG=0
INPUT_SERVICE_LOG_LEVEL=INFO

# Optional. If set, /run-funnel, /funnels, and /doctor require this header:
# X-Input-Service-Secret: <value>
INPUT_SERVICE_SECRET=

# Optional root override for config/ and data/ paths.
INPUT_SERVICE_ROOT=/absolute/path/to/automated-content/VAmk0.4/source-input/input_service

# Optional: parent directory of ``video-automation`` (folder that contains ``video-automation/config/``).
# Use if the input service cannot find ``video-automation`` by walking up from INPUT_SERVICE_ROOT.
# VIDEO_AUTOMATION_PROJECT_ROOT=

# Optional explicit clipping input directory (must match ``paths.input_folder`` in pipeline_config.json).
# Default: <parent>/video-automation/input
VIDEO_AUTOMATION_INPUT_DIR=

# Optional yt-dlp auth mode for YouTube bot / sign-in challenges.
# Prefer ONE of these:
# - Browser cookies, equivalent to: yt-dlp --cookies-from-browser chrome
# YT_DLP_COOKIES_FROM_BROWSER=chrome
# - Netscape cookies.txt, equivalent to: yt-dlp --cookies /path/to/cookies.txt
# Export from a browser extension (e.g. "Get cookies.txt LOCALLY").
# YT_DLP_COOKIES_PATH=/path/to/cookies.txt

# Optional JavaScript runtime for YouTube n-challenge solving.
# Equivalent to: yt-dlp --js-runtimes deno
# YT_DLP_JS_RUNTIME=deno
# Optional explicit Deno binary path:
# YT_DLP_DENO_PATH=/path/to/deno
