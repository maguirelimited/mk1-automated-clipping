    {
      "parameters": {
        "jsCode": "const processItem = $json || {};\nconst clips = Array.isArray(processItem.clips) ? processItem.clips : [];\nconst outputFolderId = '1O9_97jhjC__NU-Vu4yk5CMVh9ZDKvlT1'; // clips_out\n\nif (!processItem.success) {\n  throw new Error(`Pipeline failed: ${processItem.error || 'unknown error'}`);\n}\nif (clips.length === 0) {\n  throw new Error('Pipeline returned success but no clips array/items were found.');\n}\n\nreturn clips.map((clip, index) => {\n  const fileName = clip.clip_file || (String(clip.clip_path || '').split('/').pop()) || `clip_${index + 1}.mp4`;\n  const clipUrl = clip.clip_url || `/output/${fileName}`;\n  return {\n    json: {\n      run_id: processItem.run_id,\n      source_video: processItem.source_video,\n      video_basename: processItem.video_basename,\n      folder_id: outputFolderId,\n      clip_file: fileName,\n      download_url: `http://host.docker.internal:5050${clipUrl}`,\n      title: clip.title,\n      hook: clip.hook,\n      caption: clip.caption,\n      start: clip.start,\n      end: clip.end,\n      duration_sec: clip.duration_sec,\n    },\n  };\n});"
      },
