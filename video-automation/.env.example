# mk0.4 video-automation environment
# Copy to .env (or source from your process manager) and fill secrets locally.
# Values below are examples/placeholders. Replace /opt/mk04/VAmk0.4 with the
# real absolute Linux path to this repo checkout. Do not commit filled secrets.

# Required for clip selection on the default (openai) backend. Doctor checks
# presence but never prints the key.
OPENAI_API_KEY=

# Clip-selection judgement backend.
#   openai      (default) -> inline OpenAI call in scripts/select_clip.py
#   ai_service            -> call the local ai-service POST /ai/run clip_selection
# MK1 has no cloud fallback: when ai_service is selected, OpenAI is not used.
#
# Prefer setting this from the Ops UI (Settings -> Local AI & clip selection),
# which writes controls.json. Resolution order is:
#   per-run selection option -> Ops UI saved value -> this env var -> default.
# A saved Ops UI value takes precedence over this env var; these env vars are a
# fallback for env-only setups.
CLIP_SELECTION_BACKEND=openai

# Local ai-service endpoint used when CLIP_SELECTION_BACKEND=ai_service.
# ai-service owns the one-at-a-time local model lock and returns HTTP 503 AI_BUSY
# when busy; video-automation treats AI_BUSY as a retryable failure.
# Also configurable from the Ops UI (takes precedence over these env vars).
AI_SERVICE_URL=http://127.0.0.1:5075
AI_SERVICE_TIMEOUT_SECONDS=180

# GPU phase control (only relevant when CLIP_SELECTION_BACKEND=ai_service).
# WhisperX and the local LLM are both heavy GPU phases; on a ~12GB card the 14B
# model can occupy most of the VRAM and starve WhisperX. When enabled, before
# WhisperX transcription the pipeline asks Ollama to release the model
# (keep_alive=0 unload) so the two phases run sequentially, not at once.
# These can also be set from the Ops UI (Settings -> Local AI & clip selection),
# which writes controls.json; a saved UI value takes precedence over these.
# Used to reach the same Ollama instance ai-service uses; defaults match.
AI_BASE_URL=http://localhost:11434
AI_MODEL=qwen2.5:14b-instruct
LOCAL_AI_GPU_PHASE_CONTROL_ENABLED=true
# Warn (and recommend a smaller/CPU WhisperX model) if the model cannot be
# released or free VRAM stays low. Does not change the model automatically.
LOCAL_AI_WARN_ON_GPU_PRESSURE=true

# Flask bind. 0.0.0.0 exposes the service to the host network; use firewall
# rules/security groups if remote callers need access.
VIDEO_AUTOMATION_HOST=127.0.0.1
VIDEO_AUTOMATION_PORT=5050
VIDEO_AUTOMATION_DEBUG=0

# Optional. If set, every endpoint except /healthz requires:
# X-Video-Automation-Secret: <value>
VIDEO_AUTOMATION_SECRET=

# Required/recommended in Linux deployments: pin repo-owned config catalogs to
# real absolute Linux paths so process managers do not depend on cwd.
PIPELINE_CONFIG_PATH=/opt/mk04/VAmk0.4/video-automation/config/pipeline_config.json
VIDEO_PIPELINE_PROFILES_PATH=/opt/mk04/VAmk0.4/video-automation/config/video_pipeline_profiles.json

# Runtime folders come from config/pipeline_config.json by default:
# input, output, temp, jobs, analytics (relative to video-automation/).
# If you move any of these to durable mounted storage, update pipeline_config.json
# with absolute Linux paths and ensure the service user can write them.

# Processing / post-processing pipeline (MK1).
# Prefer setting these from the Ops UI (Settings -> Processing / Post-processing),
# which writes controls.json. Resolution order for each is:
#   per-run option (where applicable) -> Ops UI saved value -> env var -> default.
# A saved Ops UI value takes precedence over these env vars.
#
# Master switch: legacy = current single-pass selection + clipping (default);
# mk1 = new processing -> post-processing pipeline (sectioning, candidate
# discovery via the local ai-service, selection gate, universal conveyor).
PROCESSING_PIPELINE_MODE=legacy
# Transcript sectioning (seconds).
PROCESSING_SECTION_TARGET_DURATION_SEC=300
PROCESSING_SECTION_MAX_DURATION_SEC=420
PROCESSING_SECTION_OVERLAP_SEC=30
PROCESSING_SECTION_MIN_DURATION_SEC=60
# Section candidate discovery.
PROCESSING_MAX_CANDIDATES_PER_SECTION=3
PROCESSING_MIN_CANDIDATE_DURATION_SEC=15
PROCESSING_MAX_CANDIDATE_DURATION_SEC=120
PROCESSING_DISCOVERY_FAIL_FAST=false
# Post-processing: run the universal conveyor (off stops at the raw candidate pool).
POST_PROCESSING_ENABLED=true
# Selection gate. Mode presets tune the thresholds below; the explicit values
# are applied directly only when POST_PROCESSING_SELECTION_MODE=custom.
POST_PROCESSING_SELECTION_MODE=balanced
POST_PROCESSING_MAX_CLIPS=6
POST_PROCESSING_RESERVE_COUNT=3
POST_PROCESSING_MIN_OVERALL_POTENTIAL=7.0
POST_PROCESSING_MIN_CONFIDENCE=0.6
POST_PROCESSING_MIN_DURATION_SEC=15
POST_PROCESSING_MAX_DURATION_SEC=120
POST_PROCESSING_RESPECT_CANDIDATE_WARNINGS=true
POST_PROCESSING_RESPECT_TRANSCRIPT_QUALITY_FLAGS=true
POST_PROCESSING_ALLOW_RESERVE_CANDIDATES=true
# Universal conveyor — platform-safe format (9:16 export).
POST_PROCESSING_FORMAT_TARGET_WIDTH=1080
POST_PROCESSING_FORMAT_TARGET_HEIGHT=1920
POST_PROCESSING_FORMAT_BACKGROUND_MODE=blurred
POST_PROCESSING_FORMAT_BACKGROUND_BLUR=20:1
POST_PROCESSING_FORMAT_FFMPEG_PRESET=veryfast
POST_PROCESSING_FORMAT_VIDEO_CODEC=libx264
POST_PROCESSING_FORMAT_AUDIO_CODEC=aac
# Universal conveyor — intelligent captions.
POST_PROCESSING_CAPTIONS_FONT_FAMILY=Arial
POST_PROCESSING_CAPTIONS_FONT_SIZE=64
POST_PROCESSING_CAPTIONS_MAX_LINES=2
POST_PROCESSING_CAPTIONS_MAX_CHARS_PER_LINE=32
POST_PROCESSING_CAPTIONS_MAX_CHARS_PER_CAPTION=42
POST_PROCESSING_CAPTIONS_ENABLE_KEYWORD_HIGHLIGHTING=false
POST_PROCESSING_CAPTIONS_HIGHLIGHT_NUMBERS=false

# Optional runtime overrides. Prefer repo profiles; use these only for deploy/staging differences.
VIDEO_PIPELINE_RUNTIME_JSON=
MK04_WHISPER_MODEL=
MK04_SELECTION_MODEL=
# Transcription backend: ``whisper`` (legacy CLI, default) or ``whisperx``.
TRANSCRIBE_ENGINE=

# Optional debug/event logs (NDJSON, one object per line)
DEBUG_LOG_PATH=
AGENT_DEBUG_LOG_PATH=
DEBUG_MODE_LOG_PATH=
# Ingress breadcrumbs for /process (same NDJSON schema as DEBUG_* sinks).
PIPELINE_DIAGNOSTIC_LOG_PATH=
# When set, overrides sessionId for every NDJSON sink above (cross-process correlation).
PIPELINE_DEBUG_SESSION_ID=

# Output-funnel handoff. After each successful clipping job, video-automation
# POSTs the report to output-funnel /registrations/from-job. This is the
# primary autonomy hook: without it, clips would sit in video-automation only.
OUTPUT_FUNNEL_URL=http://127.0.0.1:5055
OUTPUT_FUNNEL_HANDOFF_ENABLED=1
# Raise from the 2s default for mk1 hardware: registration writes to SQLite
# and runs preflight, which can exceed 2s under load or slow disk.
OUTPUT_FUNNEL_HANDOFF_TIMEOUT_SEC=30
# Optional output-funnel handoff auth. If set in output-funnel, set the same
# value here so completed jobs can register downstream.
OUTPUT_FUNNEL_SECRET=
