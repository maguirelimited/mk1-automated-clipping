# mk0.4 video-automation environment
# Copy to .env (or source from your process manager) and fill secrets locally.

# Required for clip selection
OPENAI_API_KEY=

# Flask bind
VIDEO_AUTOMATION_HOST=0.0.0.0
VIDEO_AUTOMATION_PORT=5050
VIDEO_AUTOMATION_DEBUG=0

# Repo-owned config catalog
PIPELINE_CONFIG_PATH=/absolute/path/to/automated-content/VAmk0.4/video-automation/config/pipeline_config.json
VIDEO_PIPELINE_PROFILES_PATH=/absolute/path/to/automated-content/VAmk0.4/video-automation/config/video_pipeline_profiles.json

# Optional runtime overrides. Prefer repo profiles; use these only for deploy/staging differences.
VIDEO_PIPELINE_RUNTIME_JSON=
MK04_WHISPER_MODEL=
MK04_SELECTION_MODEL=

# Optional debug/event logs
DEBUG_LOG_PATH=
AGENT_DEBUG_LOG_PATH=
DEBUG_MODE_LOG_PATH=
