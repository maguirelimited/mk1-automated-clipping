{
  "database_path": "data/output_funnel.sqlite3",
  "preflight": {
    "duration_tolerance_sec": 1.0
  },
  "scheduler": {
    "default_timezone": "UTC",
    "default_lead_minutes": 180,
    "default_min_gap_minutes": 180,
    "default_max_uploads_per_day": 3
  },
  "youtube": {
    "upload_lead_minutes": 90,
    "upload_safety_buffer_minutes": 20,
    "min_publish_at_lead_minutes": 15
  },
  "x": {
    "publish_grace_minutes": 15,
    "circuit_threshold": 3,
    "circuit_pause_seconds": 900
  },
  "facebook": {
    "scheduled_publish_mode": "platform_native",
    "upload_timing": "immediate_after_validation",
    "upload_safety_buffer_minutes": 20,
    "max_schedule_horizon_days": 180,
    "circuit_threshold": 3,
    "circuit_pause_seconds": 900
  },
  "instagram": {
    "publish_grace_minutes": 15,
    "circuit_threshold": 3,
    "circuit_pause_seconds": 900
  },
  "publisher": {
    "max_attempts": 3,
    "lease_seconds": 1800
  },
  "automation": {
    "auto_schedule": true,
    "schedule_limit": 50,
    "auto_upload": false,
    "upload_limit": 1,
    "upload_worker": {
      "enabled": true,
      "interval_seconds": 60
    }
  }
}
