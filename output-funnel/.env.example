# mk0.4 output-funnel environment
# Copy to .env (or source from your process manager) and fill secrets locally.
# Values below are examples/placeholders. Replace /opt/mk04/VAmk0.4 with the
# real absolute Linux path to this repo checkout.

# Flask bind. Keep localhost unless a trusted remote caller requires access.
OUTPUT_FUNNEL_HOST=127.0.0.1
OUTPUT_FUNNEL_PORT=5055

# Optional. If set, every endpoint except /healthz requires:
# X-Output-Funnel-Secret: <value>
# Set the same value in video-automation/.env so handoff can register clips.
OUTPUT_FUNNEL_SECRET=

# Pinned absolute paths so process managers do not depend on cwd.
OUTPUT_FUNNEL_SETTINGS=/opt/mk04/VAmk0.4/output-funnel/config/settings.json
OUTPUT_FUNNEL_CHANNELS=/opt/mk04/VAmk0.4/output-funnel/config/channels.json
OUTPUT_FUNNEL_DB=/opt/mk04/VAmk0.4/output-funnel/data/output_funnel.sqlite3

# Shared with ops-ui so uploads_paused emergency stop reaches this service.
MK04_CONTROLS_FILE=/opt/mk04/VAmk0.4/ops-ui/data/controls.json

# Autonomy toggles. The defaults in settings.json already set these, but the
# env vars win on conflict and make systemd unit overrides explicit.
#
# auto_schedule: registration auto-plans publish/upload times.
OUTPUT_FUNNEL_AUTO_SCHEDULE=1
OUTPUT_FUNNEL_AUTO_SCHEDULE_LIMIT=50
# auto_upload at registration time is OFF on purpose. The upload worker below
# performs uploads when the planned upload_at time arrives.
OUTPUT_FUNNEL_AUTO_UPLOAD=0
OUTPUT_FUNNEL_AUTO_UPLOAD_LIMIT=1
# Background upload worker: polls upload-due in-process. No external cron needed.
OUTPUT_FUNNEL_UPLOAD_WORKER_ENABLED=1
OUTPUT_FUNNEL_UPLOAD_WORKER_INTERVAL=60
# Background plan worker: catches up scheduling if video-automation handoff
# failed once (e.g. network blip). Safe to leave enabled in autonomous mode.
OUTPUT_FUNNEL_PLAN_WORKER_ENABLED=1
OUTPUT_FUNNEL_PLAN_WORKER_INTERVAL=300

# Optional scheduler overrides (defaults come from settings.json).
# OUTPUT_FUNNEL_SCHEDULE_TIMEZONE=UTC
# OUTPUT_FUNNEL_SCHEDULE_LEAD_MINUTES=180
# OUTPUT_FUNNEL_SCHEDULE_MIN_GAP_MINUTES=180
# OUTPUT_FUNNEL_SCHEDULE_MAX_UPLOADS_PER_DAY=3

# YouTube OAuth artefact paths referenced by channel profiles. Tokens and
# client secrets MUST live outside the repo. Keep these on durable storage so
# refresh tokens survive restarts.
MFM_BUSINESS_AI_YT_TOKEN_FILE=/var/lib/mk04/credentials/mfm_business_ai.token.json
MFM_BUSINESS_AI_YT_CLIENT_SECRET_FILE=/var/lib/mk04/credentials/mfm_business_ai.client_secret.json

# X OAuth user-context token. The token needs tweet.write and media.write.
MFM_BUSINESS_AI_X_ACCESS_TOKEN=
MFM_BUSINESS_AI_X_TOKEN_EXPIRES_AT=

# Facebook Page Reels via Meta Graph API. Use a Page access token and keep the
# expiry mirrored here so output-funnel can warn before uploads start failing.
MFM_BUSINESS_AI_FB_PAGE_ID=
MFM_BUSINESS_AI_FB_PAGE_ACCESS_TOKEN=
MFM_BUSINESS_AI_FB_TOKEN_EXPIRES_AT=

# Instagram Reels via Instagram Graph API resumable upload. The account must be
# an Instagram professional account connected to a Page the token can manage.
MFM_BUSINESS_AI_IG_USER_ID=
MFM_BUSINESS_AI_IG_ACCESS_TOKEN=
MFM_BUSINESS_AI_IG_TOKEN_EXPIRES_AT=
