# mk04 PROD runtime identity. Copy to /etc/mk04/prod/env and edit locally.
MK04_ENV=prod
MK04_CODE_ROOT=/opt/mk04/prod/current
MK04_CONFIG_ROOT=/etc/mk04/prod
MK04_RUNTIME_ROOT=/var/lib/mk04/prod
MK04_LOG_ROOT=/var/log/mk04/prod

INPUT_SERVICE_PORT=5060
VIDEO_AUTOMATION_PORT=5050
OUTPUT_FUNNEL_PORT=5055
# Ops UI stays on loopback only. Remote access uses SSH LocalForward — see
# docs/operations/REMOTE_UI_ACCESS.md. Do not set OPS_UI_HOST=0.0.0.0.
OPS_UI_HOST=127.0.0.1
OPS_UI_PORT=5070
AI_SERVICE_PORT=5075

# Local LLM (ai-service) model backend. Defaults target a local Ollama instance.
# These are fallbacks: the Ops UI (Settings -> Local AI & clip selection) can
# override them via controls.json. Clip-selection backend defaults to ai_service;
# set CLIP_SELECTION_BACKEND=openai for legacy rollback/testing.
AI_PROVIDER=ollama
AI_MODEL=qwen2.5:14b-instruct
AI_BASE_URL=http://localhost:11434
# How long Ollama keeps the model resident in VRAM after a call. "5m" (Ollama's
# default) evicts the 14B model after the idle window so the GPU is freed for
# WhisperX; "0" unloads immediately; avoid "-1" (pins forever) on a shared GPU.
AI_KEEP_ALIVE=5m
# run-ollama.sh: auto-pull the model on startup (false avoids surprise downloads).
OLLAMA_AUTO_PULL_MODEL=false
# CLIP_SELECTION_BACKEND=ai_service   # ai_service (default) | openai (legacy)
# GPU phase control (ai_service backend only): before WhisperX, ask Ollama to
# release the model so transcription and clip selection do not fight for VRAM.
LOCAL_AI_GPU_PHASE_CONTROL_ENABLED=true
LOCAL_AI_WARN_ON_GPU_PRESSURE=true

# Retention sweeper TTLs (deploy/scripts/retention-sweeper.sh). MEDIA removes
# large media (per-job input_* copies, clip mirrors, output clips, temp scratch,
# orphaned input/ files); RETENTION removes fully-aged whole job folders incl.
# their small metadata.
MEDIA_RETENTION_DAYS=5
RETENTION_DAYS=14

# Production is the only environment allowed to use real platform uploads.
# Keep dry_run until OAuth/channel credentials are verified.
# uploading.enabled in config/environments/prod.yaml is false until armed.
MK04_UPLOAD_MODE=dry_run
# First-bootstrap / unscheduled default: manual only. Install cron deliberately later.
MK04_SCHEDULER_MODE=manual
OUTPUT_FUNNEL_PLAN_WORKER_ENABLED=0
OUTPUT_FUNNEL_UPLOAD_WORKER_ENABLED=0
OUTPUT_FUNNEL_AUTO_UPLOAD=0

# Post-processing reframing: keep production on blur_background.
# POST_PROCESSING_FORMAT_REFRAME_MODE=blur_background
# Do NOT enable in production unless explicitly approved for a controlled test:
# POST_PROCESSING_FACE_TRACK_TEST_ENABLED=false

# Fill secrets only in /etc/mk04/prod/env or service-specific files, never here.
OPENAI_API_KEY=
INPUT_SERVICE_SECRET=
VIDEO_AUTOMATION_SECRET=
OUTPUT_FUNNEL_SECRET=
YT_DLP_COOKIES_PATH=/var/lib/mk04/prod/credentials/youtube.cookies.txt
MFM_BUSINESS_AI_YT_TOKEN_FILE=/var/lib/mk04/prod/credentials/mfm_business_ai.token.json
MFM_BUSINESS_AI_YT_CLIENT_SECRET_FILE=/var/lib/mk04/prod/credentials/mfm_business_ai.client_secret.json

# ── New config layer (config/ directory) ─────────────────────────────────────
# From the Configuration & Deployment upgrade, system behaviour is now defined
# in YAML files under config/ at the repo root:
#
#   config/defaults/default.yaml       — shared defaults
#   config/environments/prod.yaml      — prod state paths, uploading enabled by default,
#                                        optional storage retention overrides
#   config/system/system.yaml          — retention baseline, disk thresholds, AI model
#   config/funnels/business.yaml       — funnel identity and platforms
#   config/platforms/<platform>.yaml   — per-platform upload/format settings
#   config/presets/<preset>.yaml       — selection and posting behaviour
#
# IMPORTANT: uploading.enabled in config/environments/prod.yaml defaults to
# false until deliberately armed. Real posts also require MK04_UPLOAD_MODE=real
# and valid destination credentials. MK04_CONFIG_UPLOAD_ENABLED is derived from
# YAML by deploy/scripts/env.sh and is not an operator override.
# The runtime kill switch (data/prod/control_state.json) and Ops UI
# uploads_paused remain deny-only controls.
# ConfigManager is implemented in a later prompt (Prompt 3).
