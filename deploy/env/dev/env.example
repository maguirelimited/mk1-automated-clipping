# mk04 DEV runtime identity. Copy to /etc/mk04/dev/env and edit locally.
MK04_ENV=dev
MK04_CODE_ROOT=/Users/anthonymaguire/VAmk0.4
MK04_CONFIG_ROOT=/etc/mk04/dev
MK04_RUNTIME_ROOT=/var/lib/mk04/dev
MK04_LOG_ROOT=/var/log/mk04/dev

INPUT_SERVICE_PORT=5160
VIDEO_AUTOMATION_PORT=5150
OUTPUT_FUNNEL_PORT=5155
OPS_UI_PORT=5170

# Safety rail: dev may plan and exercise queues, but must not call platform APIs.
MK04_UPLOAD_MODE=dry_run
MK04_SCHEDULER_MODE=manual
OUTPUT_FUNNEL_PLAN_WORKER_ENABLED=0
OUTPUT_FUNNEL_UPLOAD_WORKER_ENABLED=0
OUTPUT_FUNNEL_AUTO_UPLOAD=0

# Fill secrets only in /etc/mk04/dev/env or service-specific files, never here.
OPENAI_API_KEY=
INPUT_SERVICE_SECRET=
VIDEO_AUTOMATION_SECRET=
OUTPUT_FUNNEL_SECRET=
YT_DLP_COOKIES_PATH=/var/lib/mk04/dev/credentials/youtube.cookies.txt
MFM_BUSINESS_AI_YT_TOKEN_FILE=/var/lib/mk04/dev/credentials/mfm_business_ai.token.json
MFM_BUSINESS_AI_YT_CLIENT_SECRET_FILE=/var/lib/mk04/dev/credentials/mfm_business_ai.client_secret.json
