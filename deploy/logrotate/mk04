# mk0.4 file-based log rotation. Install at /etc/logrotate.d/mk04.
#
# systemd-journald handles stdout/stderr for the service units; this only
# covers file sinks the services write directly (debug NDJSON, analytics
# JSONL, ops-ui audit, etc.). Sizes are conservative to survive long runs
# without filling /var on a single-host mk1 box.

# video-automation debug / agent / pipeline NDJSON sinks.
/var/log/mk04/*/video-automation/*.log
/var/log/mk04/*/video-automation/*.ndjson
{
    weekly
    rotate 8
    size 100M
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}

# Analytics events. Append-only JSONL with potentially many small rows.
/var/lib/mk04/*/video-automation/analytics/*.jsonl
{
    monthly
    rotate 12
    size 200M
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}

# ops-ui app log (if redirected from journald to a file by a process manager).
/var/log/mk04/*/ops-ui/*.log
{
    weekly
    rotate 4
    size 50M
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}
