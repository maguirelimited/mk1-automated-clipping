# mk0.4 file-based log rotation for deploy sinks under /var/log/mk04.
#
# Prefer installing from config:
#   sudo ./deploy/scripts/install-log-rotation.sh prod
#
# That renders this file from storage.log_rotation (max_bytes, backup_count,
# compress). Values below match the system defaults and are kept as a fallback
# template when install has not been run yet.
#
# systemd-journald handles stdout/stderr for service units (see
# deploy/journald/mk04.conf.example and install-log-rotation.sh).
#
# Project logs under logs/<env>/ are rotated by:
#   scripts/ops/run-log-rotation.sh
# Expired rotated logs are removed by the retention engine (logs_days).

/var/log/mk04/*/*/*.log
/var/log/mk04/*/*/*.ndjson
/var/log/mk04/*/*/*.jsonl
{
    daily
    rotate 8
    size 100M
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
}
